# ============================================
# Development Environment Template
# ============================================
# Copy this file to .env.dev and adjust as needed

# ============================================
# Core Settings
# ============================================
NODE_ENV=development

# ============================================
# URLs (Local development)
# ============================================
APP_URL=http://localhost:5173
API_URL=http://localhost:3001
BETTER_AUTH_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001/ws

# ============================================
# Database (Docker - exposed on localhost:5432)
# ============================================
POSTGRES_USER=flowpig
POSTGRES_PASSWORD=flowpig_dev_password
POSTGRES_DB=flowpig_dev

# Connection string for local dev
DATABASE_URL=postgresql://flowpig:flowpig_dev_password@localhost:5432/flowpig_dev

# ============================================
# Redis (Docker - exposed on localhost:6379)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Auth (Any secret works for dev)
# ============================================
BETTER_AUTH_SECRET=dev_secret_not_secure_but_fine_for_local_development
# Legacy fallback supported by the API, but prefer BETTER_AUTH_SECRET.
AUTH_SECRET=

# ============================================
# Storage
# ============================================
STORAGE_DRIVER=filesystem
UPLOAD_ROOT=./data/uploads

# ============================================
# AI Providers (Optional)
# ============================================
AI_PROVIDER=openai
AI_API_KEY=                    # Add your key to test AI features
AI_API_URL=
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================
# OAuth (Optional - can leave blank for dev)
# ============================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
