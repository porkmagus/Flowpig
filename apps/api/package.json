{
  "name": "@flowpigdev/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node -e \"require('dotenv').config({path:require('path').resolve(process.cwd(),'../../.env.dev')})\" && npx nitro dev",
    "dev:legacy": "node --import tsx src/server.ts",
    "dev:watch": "tsx watch src/server.ts",
    "build": "npx nitro build",
    "build:legacy": "tsc",
    "start": "node .output/server/index.mjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.88.0",
    "@fastify/cors": "11.2.0",
    "@fastify/multipart": "10.0.0",
    "@fastify/websocket": "11.2.0",
    "@flowpigdev/contracts": "*",
    "@flowpigdev/db": "*",
    "better-auth": "1.6.2",
    "dotenv": "^17.4.2",
    "fastify": "5.8.4",
    "fastify-plugin": "5.1.0",
    "nitro": "^3.0.260311-beta",
    "openai": "6.34.0",
    "stripe": "^16.0.0",

    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "workflow": "^4.2.2"
  }
}
