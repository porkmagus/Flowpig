# ============================================
# Production Environment Template
# ============================================
# Copy this file to .env.prod and fill in your values
# DO NOT commit .env.prod to git!

# ============================================
# Core Settings
# ============================================
NODE_ENV=production

# ============================================
# URLs (Update with your actual domains)
# ============================================
APP_URL=https://app.flowpig.dev
API_URL=https://api.flowpig.dev
BETTER_AUTH_URL=https://api.flowpig.dev
WS_URL=wss://api.flowpig.dev

# ============================================
# Database (PostgreSQL 17)
# ============================================
# These are used by the Docker container
POSTGRES_USER=flowpig
POSTGRES_PASSWORD=GENERATE_A_STRONG_PASSWORD_HERE_MIN_32_CHARS
POSTGRES_DB=flowpig_prod

# This is the full connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql://flowpig:YOUR_PASSWORD@postgres:5432/flowpig_prod

# ============================================
# Redis
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# Auth (CRITICAL - Generate strong secret!)
# ============================================
# Generate with: openssl rand -base64 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=YOUR_MIN_32_CHARACTER_SECRET_HERE

# ============================================
# Storage
# ============================================
STORAGE_DRIVER=filesystem
UPLOAD_ROOT=/app/data/uploads

# ============================================
# AI Providers (Optional)
# ============================================
AI_PROVIDER=openai
AI_API_KEY=sk-...
AI_API_URL=          # Optional - for custom endpoints
AI_MODEL=gpt-4o

# ============================================
# OAuth Providers (Optional)
# ============================================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================
# S3/Storage (Optional - if not using filesystem)
# ============================================
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ============================================
# Email (Optional - for notifications)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@flowpig.dev
