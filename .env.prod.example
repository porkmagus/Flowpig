NODE_ENV=production
APP_URL=https://app.flowpig.dev
API_URL=https://api.flowpig.dev
BETTER_AUTH_URL=https://api.flowpig.dev
DATABASE_URL=postgresql://flowpig:replace_me@postgres:5432/flowpig_prod
REDIS_URL=redis://redis:6379
