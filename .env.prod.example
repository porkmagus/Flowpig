# ============================================
# Production Environment Template
# ============================================
# Copy to .env.prod and fill in actual values
#
# Usage:
#   cp .env.prod.example .env.prod
#   docker compose -f compose.prod.yml --env-file .env.prod up -d

# ============================================
# Application URLs
# ============================================
# APP_URL must be the frontend origin (e.g. https://app.flowpig.dev).
# If your frontend is on a different origin, you can also set FRONTEND_URL.
APP_URL=https://flowpig.example.com
API_URL=https://api.flowpig.example.com
BETTER_AUTH_URL=https://api.flowpig.example.com
# Optional: add extra origins for Better Auth (comma-separated).
# BETTER_AUTH_TRUSTED_ORIGINS=https://app.flowpig.dev
VITE_API_URL=https://api.flowpig.example.com
VITE_WS_URL=wss://api.flowpig.example.com/ws

# ============================================
# Database Configuration
# ============================================
DB_USER=flowpig_prod
DB_PASSWORD=your_secure_postgres_password_here_min_16_chars
DB_NAME=flowpig_prod

# ============================================
# Redis Configuration
# ============================================
REDIS_PASSWORD=your_secure_redis_password_here_min_16_chars

# ============================================
# Authentication
# ============================================
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_secret_key_here_min_32_characters_long_secure_random
# Legacy fallback supported by the API, but prefer BETTER_AUTH_SECRET.
AUTH_SECRET=

# ============================================
# Storage Configuration
# ============================================
# Options: filesystem, s3
STORAGE_DRIVER=filesystem
UPLOAD_ROOT=/app/data/uploads
# Optional override. Defaults to ${API_URL}/uploads when omitted.
STORAGE_PUBLIC_URL=

# ============================================
# AI Integration (Optional)
# ============================================
AI_PROVIDER=openai
AI_API_KEY=your_openai_api_key_here
AI_API_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================
# OAuth Providers (Optional)
# ============================================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
