{
  "name": "flowpigdev",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "doctor:native": "node ./scripts/check-native-deps.cjs",
    "dev:web": "npm --workspace @flowpigdev/web run dev",
    "dev:api": "npm --workspace @flowpigdev/api run dev",
    "dev:infra": "docker compose -f ops/docker/compose.dev.yml --env-file .env.dev up -d",
    "dev:infra:down": "docker compose -f ops/docker/compose.dev.yml --env-file .env.dev down",
    "db:generate": "npm --workspace @flowpigdev/db run generate",
    "db:migrate": "npm --workspace @flowpigdev/db run migrate",
    "db:deploy": "npm --workspace @flowpigdev/db run deploy",
    "db:seed": "npm --workspace @flowpigdev/db run seed",
    "db:studio": "npm --workspace @flowpigdev/db run studio",
    "build:api": "npm --workspace @flowpigdev/api run build",
    "build:web": "npm --workspace @flowpigdev/web run build",
    "build:all": "npm run build:api && npm run build:web",
    "prod:build": "docker compose -f compose.prod.yml build",
    "prod:up": "docker compose -f compose.prod.yml --env-file .env.prod up -d",
    "prod:down": "docker compose -f compose.prod.yml down",
    "prod:logs": "docker compose -f compose.prod.yml logs -f",
    "prod:ps": "docker compose -f compose.prod.yml ps",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "better-auth": "1.6.2",
    "dotenv": "^17.4.2",
    "framer-motion": "12.38.0",
    "zod": "4.3.6"
  }
}
