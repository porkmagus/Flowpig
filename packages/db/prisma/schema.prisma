// Git Integration Models
model GitIntegration {
  id                String             @id @default(cuid())
  workspaceId       String             @unique @map("workspace_id")
  provider          GitProvider        @default(GITHUB)
  installationId    String?            @map("installation_id")
  accessToken       String?            @map("access_token")
  refreshToken      String?            @map("refresh_token")
  tokenExpiresAt    DateTime?          @map("token_expires_at")
  organization      String?            @map("organization")
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pullRequests      GitPullRequest[]
  commits           GitCommit[]
  
  @@index([workspaceId])
  @@index([provider, installationId])
  @@map("git_integrations")
}

model GitRepository {
  id                String             @id @default(cuid())
  integrationId     String             @map("integration_id")
  externalId        String             @unique @map("external_id")
  name              String
  fullName          String             @map("full_name")
  url               String
  defaultBranch     String             @default("main") @map("default_branch")
  isPrivate         Boolean            @default(true) @map("is_private")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  
  pullRequests      GitPullRequest[]
  
  @@index([integrationId])
  @@map("git_repositories")
}

model GitPullRequest {
  id                String             @id @default(cuid())
  integrationId     String             @map("integration_id")
  repositoryId        String?            @map("repository_id")
  externalId        String             @unique @map("external_id")
  number            Int
  title             String
  description       String?
  state             PullRequestState   @default(OPEN)
  url               String
  branchName        String             @map("branch_name")
  baseBranch        String             @map("base_branch")
  authorName        String             @map("author_name")
  authorAvatar      String?            @map("author_avatar")
  draft             Boolean            @default(false)
  mergedAt          DateTime?          @map("merged_at")
  closedAt          DateTime?          @map("closed_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  
  integration       GitIntegration     @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  repository        GitRepository?     @relation(fields: [repositoryId], references: [id])
  issueLinks        IssueGitLink[]
  
  @@unique([integrationId, number])
  @@index([integrationId])
  @@index([repositoryId])
  @@index([state])
  @@map("git_pull_requests")
}

model GitCommit {
  id                String             @id @default(cuid())
  integrationId     String             @map("integration_id")
  sha               String             @unique
  message           String
  authorName        String             @map("author_name")
  authorEmail       String             @map("author_email")
  authorDate        DateTime           @map("author_date")
  url               String
  createdAt         DateTime           @default(now()) @map("created_at")
  
  integration       GitIntegration     @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  issueLinks        IssueGitLink[]
  
  @@index([integrationId])
  @@index([sha])
  @@map("git_commits")
}

model IssueGitLink {
  id                String             @id @default(cuid())
  issueId           String             @map("issue_id")
  pullRequestId     String?            @map("pull_request_id")
  commitId          String?            @map("commit_id")
  branchName        String?            @map("branch_name")
  linkType          GitLinkType        @default(MANUAL) @map("link_type")
  createdAt         DateTime           @default(now()) @map("created_at")
  
  issue             Issue              @relation(fields: [issueId], references: [id], onDelete: Cascade)
  pullRequest       GitPullRequest?    @relation(fields: [pullRequestId], references: [id])
  commit            GitCommit?         @relation(fields: [commitId], references: [id])
  
  @@unique([issueId, pullRequestId, commitId])
  @@index([issueId])
  @@index([pullRequestId])
  @@index([commitId])
  @@map("issue_git_links")
}

// Enums for Git
enum GitProvider {
  GITHUB
  GITLAB
  BITBUCKET
  AZURE_DEVOPS
}

enum PullRequestState {
  OPEN
  CLOSED
  MERGED
}

enum GitLinkType {
  AUTO    // Auto-linked via branch name or commit message
  MANUAL  // Manually linked by user
  WEBHOOK // Linked via webhook
}

// Enums for Note Sharing
enum PublicAccessLevel {
  PRIVATE    // Only invited users/workspace members
  READONLY   // Anyone with link can view
  COMMENT    // Anyone with link can comment
  EDIT       // Anyone with link can edit (public wiki)
}

enum SharePermission {
  VIEW       // Can only view
  COMMENT    // Can view and comment
  EDIT       // Can view, comment, and edit
}
