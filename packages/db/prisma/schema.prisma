generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Better Auth Tables
model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String    @map("providerAccountId")
  providerId            String    @map("provider")
  type                  String?
  refreshToken          String?   @map("refresh_token")
  accessToken           String?   @map("access_token")
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  tokenType             String?   @map("token_type")
  scope                 String?
  idToken               String?   @map("id_token")
  sessionState          String?   @map("session_state")
  password              String?   @map("password_hash")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  token        String   @unique @map("session_token")
  userId       String
  expiresAt    DateTime @map("expires")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ipAddress    String?
  userAgent    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String   @unique @map("token")
  expiresAt  DateTime @map("expires")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@map("verification")
}

// Core Application Tables
model Workspace {
  id                   String              @id @default(cuid())
  name                 String
  slug                 String              @unique
  description          String?
  icon                 String?
  color                String              @default("#5E6AD2")
  inviteCode           String              @unique @default(cuid())
  ownerId              String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  deletedAt            DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  plan                 String              @default("FREE")
  settings             Json?               @default("{}")
  activities           Activity[]
  agentConversations   AgentConversation[]
  aiUsage              AIUsage[]
  billing              Billing?
  comments             Comment[]
  cycles               Cycle[]
  databases            Database[]
  groups               Group[]
  initiatives          Initiative[]
  invitations          Invitation[]
  issueNoteLinks       IssueNoteLink[]
  issueSuggestions     IssueSuggestion[]
  issues               Issue[]
  labels               Label[]
  notes                Note[]
  notifications        Notification[]
  personalTasks        PersonalTask[]
  projects             Project[]
  slackIntegration     SlackIntegration?
  retros               SprintRetro[]
  teams                Team[]
  templates            Template[]
  issueViews           IssueView[]
  triageRules          TriageRule[]
  uploads              Upload[]
  webhooks             Webhook[]
  attachments          IssueAttachment[]
  members              WorkspaceMember[]
  gitIntegration       GitIntegration?
  owner                User                @relation(fields: [ownerId], references: [id])

  @@index([slug])
  @@index([ownerId])
  @@map("workspaces")
}

model Billing {
  id                   String    @id @default(cuid())
  workspaceId          String    @unique
  plan                 String    @default("FREE")
  status               String    @default("ACTIVE")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  lastInvoiceId        String?
  lastInvoiceUrl       String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoices             Invoice[]

  @@index([workspaceId])
  @@map("billing")
}

model Invoice {
  id              String    @id @default(cuid())
  billingId       String
  stripeInvoiceId String    @unique
  amount          Int
  currency        String    @default("USD")
  status          String
  pdfUrl          String?
  hostedUrl       String?
  periodStart     DateTime?
  periodEnd       DateTime?
  createdAt       DateTime  @default(now())
  billing         Billing   @relation(fields: [billingId], references: [id], onDelete: Cascade)

  @@index([billingId])
  @@index([stripeInvoiceId])
  @@map("invoices")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

model Group {
  id          String        @id @default(cuid())
  workspaceId String
  name        String
  description String?
  color       String        @default("#5E6AD2")
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  members     GroupMember[]
  creator     User          @relation(fields: [createdById], references: [id])
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([deletedAt])
  @@map("groups")
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  addedById String?
  addedAt   DateTime @default(now())
  addedBy   User?    @relation("GroupMemberAddedBy", fields: [addedById], references: [id])
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model PersonalTask {
  id          String             @id @default(cuid())
  workspaceId String             @map("workspace_id")
  userId      String             @map("user_id")
  title       String
  description String?
  status      PersonalTaskStatus @default(TODO)
  dueDate     DateTime?          @map("due_date")
  completedAt DateTime?          @map("completed_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId])
  @@index([workspaceId, status])
  @@index([userId, status])
  @@index([deletedAt])
  @@map("personal_tasks")
}

model Invitation {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole @default(MEMBER)
  token       String        @unique
  status      InviteStatus  @default(PENDING)
  invitedById String
  expiresAt   DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  invitedBy   User          @relation("SentInvitations", fields: [invitedById], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@index([token])
  @@index([status])
  @@map("invitations")
}

model Team {
  id                 String              @id @default(cuid())
  workspaceId        String
  name               String
  key                String
  color              String              @default("#5E6AD2")
  description        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  autoCloseDays      Int?                @map("auto_close_days")
  autoCloseStateId   String?             @map("auto_close_state_id")
  autoArchiveDays    Int?                @map("auto_archive_days")
  triageOwnerId      String?             @map("triage_owner_id")
  triageSlackChannel String?             @map("triage_slack_channel")
  intakeConfig       Json?               @map("intake_config")
  settings           Json?               @default("{}")
  cycles             Cycle[]
  issues             Issue[]
  members            TeamMember[]
  workflowStates     TeamWorkflowState[]
  triageOwner        User?               @relation("TriageOwner", fields: [triageOwnerId], references: [id])
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  triageRules        TriageRule[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@map("teams")
}

model TriageRule {
  id             String    @id @default(cuid())
  teamId         String    @map("team_id")
  workspaceId    String    @map("workspace_id")
  name           String
  conditionType  String    @map("condition_type")
  conditionValue String?   @map("condition_value")
  actionType     String    @map("action_type")
  actionValue    String    @map("action_value")
  isActive       Boolean   @default(true) @map("is_active")
  order          Int       @default(0)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  team           Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([teamId, isActive])
  @@index([workspaceId])
  @@map("triage_rules")
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

model TeamWorkflowState {
  id          String     @id @default(cuid())
  teamId      String     @map("team_id")
  name        String
  key         String
  color       String     @default("#8A8F98")
  category    IssueState
  position    Int
  isDefault   Boolean    @default(false) @map("is_default")
  isTerminal  Boolean    @default(false) @map("is_terminal")
  isTriage    Boolean    @default(false) @map("is_triage")
  isDuplicate Boolean    @default(false) @map("is_duplicate")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  issues      Issue[]
  team        Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, key])
  @@unique([teamId, position])
  @@index([teamId])
  @@index([teamId, isDefault])
  @@map("team_workflow_states")
}

model Issue {
  id                 String              @id @default(cuid())
  identifier         String
  workspaceId        String
  teamId             String
  title              String
  description        Json?
  searchVector       Unsupported("tsvector")? @map("search_vector")
  state              IssueState          @default(BACKLOG)
  priority           Priority            @default(NO_PRIORITY)
  creatorId          String
  assigneeId         String?
  cycleId            String?
  projectId          String?
  parentId           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  completedAt        DateTime?
  dueDate            DateTime?
  deletedAt          DateTime?
  estimate           Int?
  workflowStateId    String?             @map("workflow_state_id")
  archivedAt         DateTime?           @map("archived_at")
  activities         Activity[]
  agentConversations AgentConversation[] @relation("AgentConversationIssue")
  comments           Comment[]
  notifications      Notification[]
  linkedNotes        IssueNoteLink[]
  relations          IssueRelation[]     @relation("IssueRelations")
  relatedTo          IssueRelation[]     @relation("RelatedToIssue")
  subscriptions      IssueSubscription[]
  IssueSuggestion    IssueSuggestion[]
  attachments        IssueAttachment[]
  gitLinks           IssueGitLink[]
  assignee           User?               @relation("IssueAssignee", fields: [assigneeId], references: [id])
  creator            User                @relation("IssueCreator", fields: [creatorId], references: [id])
  cycle              Cycle?              @relation(fields: [cycleId], references: [id])
  parent             Issue?              @relation("SubIssues", fields: [parentId], references: [id])
  children           Issue[]             @relation("SubIssues")
  project            Project?            @relation("ProjectIssues", fields: [projectId], references: [id])
  team               Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  workflowState      TeamWorkflowState?  @relation(fields: [workflowStateId], references: [id])
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  labels             Label[]             @relation("IssueToLabel")

  @@unique([workspaceId, identifier])
  @@index([workspaceId])
  @@index([teamId])
  @@index([state])
  @@index([assigneeId])
  @@index([cycleId])
  @@index([projectId])
  @@index([workflowStateId])
  @@index([deletedAt])
  @@index([archivedAt])
  @@map("issues")
}

model IssueSubscription {
  id        String   @id @default(cuid())
  issueId   String   @map("issue_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([issueId, userId])
  @@index([issueId])
  @@index([userId])
  @@map("issue_subscriptions")
}

model NoteSubscription {
  id        String   @id @default(cuid())
  noteId    String   @map("note_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noteId, userId])
  @@index([noteId])
  @@index([userId])
  @@map("note_subscriptions")
}

model IssueSuggestion {
  id                  String    @id @default(cuid())
  issueId             String    @map("issue_id")
  workspaceId         String    @map("workspace_id")
  suggestedAssigneeId String?   @map("suggested_assignee_id")
  suggestedPriority   String?   @map("suggested_priority")
  suggestedLabels     String[]  @map("suggested_labels")
  suggestedProjectId  String?   @map("suggested_project_id")
  assigneeConfidence  Int?      @map("assignee_confidence")
  priorityConfidence  Int?      @map("priority_confidence")
  reasoning           String?
  wasApplied          Boolean   @default(false) @map("was_applied")
  appliedAt           DateTime? @map("applied_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  issue               Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  suggestedAssignee   User?     @relation("SuggestedAssignee", fields: [suggestedAssigneeId], references: [id])
  suggestedProject    Project?  @relation(fields: [suggestedProjectId], references: [id])
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([workspaceId])
  @@index([createdAt])
  @@map("issue_suggestions")
}

model Label {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  color       String    @default("#5E6AD2")
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issues      Issue[]   @relation("IssueToLabel")

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("labels")
}

model Cycle {
  id          String        @id @default(cuid())
  workspaceId String
  teamId      String
  number      Int
  name        String?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean       @default(false)
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  sprintGoal  String?
  capacity    Int?
  team        Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issues      Issue[]
  retros      SprintRetro[]

  @@unique([teamId, number])
  @@index([workspaceId])
  @@index([teamId])
  @@index([isActive])
  @@map("cycles")
}

model SprintRetro {
  id          String    @id @default(cuid())
  cycleId     String
  workspaceId String
  wentWell    String?
  toImprove   String?
  actionItems String?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  cycle       Cycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([cycleId])
  @@index([workspaceId])
  @@map("sprint_retros")
}

model Project {
  id              String            @id @default(cuid())
  workspaceId     String
  name            String
  description     String?
  status          ProjectStatus     @default(PLANNED)
  startDate       DateTime?
  targetDate      DateTime?
  leadId          String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  initiativeId    String?
  suggestedIssues IssueSuggestion[]
  issues          Issue[]           @relation("ProjectIssues")
  milestones      Milestone[]
  initiative      Initiative?       @relation(fields: [initiativeId], references: [id])
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([initiativeId])
  @@index([status])
  @@map("projects")
}

model Initiative {
  id               String           @id @default(cuid())
  workspaceId      String
  name             String
  description      String?
  status           InitiativeStatus @default(PLANNED)
  problemStatement String?
  customerOutcome  String?
  successMetric    String?
  launchSummary    String?
  targetDate       DateTime?
  leadId           String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects         Project[]

  @@index([workspaceId])
  @@index([status])
  @@map("initiatives")
}

model Milestone {
  id                    String                @id @default(cuid())
  projectId             String
  name                  String
  description           String?
  targetDate            DateTime?
  completedAt           DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  deletedAt             DateTime?
  blockedByDependencies MilestoneDependency[] @relation("BlockedMilestone")
  blockingDependencies  MilestoneDependency[] @relation("BlockingMilestone")
  project               Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, deletedAt])
  @@index([targetDate])
  @@map("milestones")
}

model MilestoneDependency {
  id                  String    @id @default(cuid())
  blockingMilestoneId String
  blockedMilestoneId  String
  createdAt           DateTime  @default(now())
  blockedMilestone    Milestone @relation("BlockedMilestone", fields: [blockedMilestoneId], references: [id], onDelete: Cascade)
  blockingMilestone   Milestone @relation("BlockingMilestone", fields: [blockingMilestoneId], references: [id], onDelete: Cascade)

  @@unique([blockingMilestoneId, blockedMilestoneId])
  @@index([blockingMilestoneId])
  @@index([blockedMilestoneId])
  @@map("milestone_dependencies")
}

model Database {
  id             String             @id @default(cuid())
  workspaceId    String
  name           String
  description    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  accessSettings Json?              @default("{}")
  properties     DatabaseProperty[]
  rows           DatabaseRow[]
  views          DatabaseView[]
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("databases")
}

model DatabaseView {
  id         String           @id @default(cuid())
  databaseId String
  name       String
  type       DatabaseViewType @default(TABLE)
  config     Json?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  database   Database         @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
  @@map("database_views")
}

model DatabaseProperty {
  id         String               @id @default(cuid())
  databaseId String
  name       String
  type       DatabasePropertyType
  config     Json?
  order      Int                  @default(0)
  required   Boolean              @default(false)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  cells      DatabaseCell[]
  database   Database             @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
  @@index([databaseId, order])
  @@map("database_properties")
}

model DatabaseRow {
  id         String         @id @default(cuid())
  databaseId String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?
  cells      DatabaseCell[]
  database   Database       @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
  @@index([databaseId, createdAt])
  @@map("database_rows")
}

model DatabaseCell {
  id         String           @id @default(cuid())
  rowId      String
  propertyId String
  value      Json?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  property   DatabaseProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  row        DatabaseRow      @relation(fields: [rowId], references: [id], onDelete: Cascade)

  @@unique([rowId, propertyId])
  @@index([rowId])
  @@index([propertyId])
  @@map("database_cells")
}

model Comment {
  id          String            @id @default(cuid())
  workspaceId String
  issueId     String?
  parentId    String?
  content     String
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
  blockId     String?           @map("block_id")
  blockType   String?           @map("block_type")  // paragraph, heading, list, etc.
  noteId      String?
  reactions   CommentReaction[]
  creator     User              @relation(fields: [createdById], references: [id])
  issue       Issue?            @relation(fields: [issueId], references: [id], onDelete: Cascade)
  note        Note?             @relation(fields: [noteId], references: [id], onDelete: Cascade)
  parent      Comment?          @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[]         @relation("CommentReplies")
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([issueId])
  @@index([noteId])
  @@index([blockId])
  @@index([parentId])
  @@index([createdAt])
  @@map("comments")
}

model CommentReaction {
  id        String    @id @default(cuid())
  commentId String
  userId    String
  emoji     String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  comment   Comment   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId, deletedAt])
  @@index([userId])
  @@map("comment_reactions")
}

model Activity {
  id          String       @id @default(cuid())
  workspaceId String
  issueId     String
  actorId     String
  type        ActivityType
  description String
  metadata    Json?
  createdAt   DateTime     @default(now())
  actor       User         @relation(fields: [actorId], references: [id])
  issue       Issue        @relation(fields: [issueId], references: [id], onDelete: Cascade)
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([issueId])
  @@index([createdAt])
  @@map("activities")
}

model IssueRelation {
  id             String            @id @default(cuid())
  issueId        String
  relatedIssueId String
  type           IssueRelationType
  createdAt      DateTime          @default(now())
  deletedAt      DateTime?
  issue          Issue             @relation("IssueRelations", fields: [issueId], references: [id], onDelete: Cascade)
  relatedIssue   Issue             @relation("RelatedToIssue", fields: [relatedIssueId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([relatedIssueId])
  @@map("issue_relations")
}

model IssueNoteLink {
  id          String    @id @default(cuid())
  issueId     String    @map("issue_id")
  noteId      String    @map("note_id")
  workspaceId String    @map("workspace_id")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  issue       Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  note        Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([issueId, noteId])
  @@index([issueId])
  @@index([noteId])
  @@index([workspaceId])
  @@index([deletedAt])
  @@map("issue_note_links")
}

model Note {
  id                 String              @id @default(cuid())
  workspaceId        String
  title              String
  slug               String
  content            Json
  searchVector       Unsupported("tsvector")? @map("search_vector")
  emoji              String?             @default("📄")
  coverImage         String?
  isArchived         Boolean             @default(false)
  isPublished        Boolean             @default(false)
  publicAccess       PublicAccessLevel   @default(PRIVATE) @map("public_access")
  shareToken         String?             @unique @map("share_token")
  parentId           String?
  createdById        String
  lastEditedById     String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  accessSettings     Json?               @default("{}")
  agentConversations AgentConversation[] @relation("AgentConversationNote")
  comments           Comment[]
  notifications      Notification[]
  linkedIssues       IssueNoteLink[]
  subscriptions      NoteSubscription[]
  shares             NoteShare[]
  versions           NoteVersion[]
  creator            User                @relation("NoteCreator", fields: [createdById], references: [id])
  lastEditor         User                @relation("NoteEditor", fields: [lastEditedById], references: [id])
  parent             Note?               @relation("NoteChildren", fields: [parentId], references: [id])
  children           Note[]              @relation("NoteChildren")
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([parentId])
  @@index([createdById])
  @@index([publicAccess])
  @@index([shareToken])
  @@map("notes")
}

model NoteVersion {
  id          String    @id @default(cuid())
  noteId      String    @map("note_id")
  title       String
  content     Json
  emoji       String?   @default("📄")
  coverImage  String?
  editedById  String    @map("edited_by_id")
  editReason  String?   @map("edit_reason")
  createdAt   DateTime  @default(now()) @map("created_at")
  
  note        Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  editedBy    User      @relation(fields: [editedById], references: [id])
  
  @@index([noteId])
  @@index([createdAt])
  @@map("note_versions")
}

model NoteShare {
  id          String    @id @default(cuid())
  noteId      String    @map("note_id")
  userId      String?   @map("user_id")
  email       String?   @map("email")
  permission  SharePermission @default(VIEW) @map("permission")
  invitedById String    @map("invited_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  acceptedAt  DateTime? @map("accepted_at")
  deletedAt   DateTime? @map("deleted_at")
  
  note        Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("NoteShareInvitedBy", fields: [invitedById], references: [id])
  
  @@unique([noteId, userId])
  @@unique([noteId, email])
  @@index([noteId])
  @@index([userId])
  @@index([email])
  @@map("note_shares")
}

model AgentConversation {
  id              String             @id @default(cuid())
  workspaceId     String
  userId          String
  relatedIssueId  String?
  relatedNoteId   String?
  contextSnapshot Json?
  status          ConversationStatus @default(ACTIVE)
  summary         String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  actions         AgentAction[]
  relatedIssue    Issue?             @relation("AgentConversationIssue", fields: [relatedIssueId], references: [id])
  relatedNote     Note?              @relation("AgentConversationNote", fields: [relatedNoteId], references: [id])
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages        AgentMessage[]

  @@index([workspaceId])
  @@index([userId])
  @@index([status])
  @@map("agent_conversations")
}

model AgentMessage {
  id             String            @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  toolCalls      Json?
  visibleContext Json?
  createdAt      DateTime          @default(now())
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("agent_messages")
}

model AgentAction {
  id                   String            @id @default(cuid())
  conversationId       String
  type                 ActionType
  status               ActionStatus      @default(PENDING)
  payload              Json
  result               Json?
  error                String?
  requiresConfirmation Boolean           @default(false)
  confirmedAt          DateTime?
  confirmedBy          String?
  executedAt           DateTime?
  createdAt            DateTime          @default(now())
  conversation         AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([status])
  @@index([type])
  @@map("agent_actions")
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  content     String
  workspaceId String?
  issueId     String?
  noteId      String?
  actorId     String?
  metadata    Json?
  isRead      Boolean          @default(false)
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  deletedAt   DateTime?
  user        User              @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor       User?             @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  workspace   Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  issue       Issue?            @relation(fields: [issueId], references: [id], onDelete: SetNull)
  note        Note?             @relation(fields: [noteId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([workspaceId])
  @@index([issueId])
  @@index([noteId])
  @@index([actorId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("notifications")
}

model Upload {
  id            String    @id @default(cuid())
  workspaceId   String
  uploadedById  String
  key           String    @unique
  originalName  String
  contentType   String
  size          Int
  url           String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  
  workspace     Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedBy    User               @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  attachments   IssueAttachment[]

  @@index([workspaceId])
  @@index([uploadedById])
  @@index([deletedAt])
  @@map("uploads")
}

model IssueAttachment {
  id          String    @id @default(cuid())
  issueId     String
  uploadId    String
  workspaceId String
  attachedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  
  issue       Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  upload      Upload    @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  attachedBy  User?     @relation(fields: [attachedById], references: [id], onDelete: SetNull)

  @@index([issueId])
  @@index([uploadId])
  @@index([workspaceId])
  @@index([deletedAt])
  @@map("issue_attachments")
}

model Template {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  description String?
  type        TemplateType
  icon        String?      @default("📋")
  color       String?      @default("#5E6AD2")
  content     Json
  isDefault   Boolean      @default(false)
  isPublic    Boolean      @default(false)
  usageCount  Int          @default(0)
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  createdBy   User         @relation(fields: [createdById], references: [id])
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, type])
  @@index([workspaceId, isDefault])
  @@index([createdById])
  @@index([deletedAt])
  @@map("templates")
}

model IssueView {
  id          String    @id @default(cuid())
  workspaceId String
  createdById String
  name        String
  filters     Json      @default("{}")
  sort        Json      @default("{}")
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User      @relation(fields: [createdById], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, isDefault])
  @@index([createdById])
  @@index([deletedAt])
  @@map("issue_views")
}

model Webhook {
  id             String            @id @default(cuid())
  workspaceId    String
  name           String
  url            String
  secret         String
  isActive       Boolean           @default(true)
  lastUsedAt     DateTime?
  failureCount   Int               @default(0)
  createdById    String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  disabledAt     DateTime?
  disabledReason String?
  deliveries     WebhookDelivery[]
  events         WebhookEvent[]
  createdBy      User              @relation(fields: [createdById], references: [id])
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@index([createdById])
  @@map("webhooks")
}

model WebhookEvent {
  id          String   @id @default(cuid())
  webhookId   String
  event       String
  createdAt   DateTime @default(now())
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@unique([webhookId, event])
  @@index([webhookId])
  @@map("webhook_events")
}

model WebhookDelivery {
  id           String         @id @default(cuid())
  webhookId    String
  event        String
  payload      Json
  status       DeliveryStatus @default(PENDING)
  statusCode   Int?
  response     String?
  error        String?
  attemptCount Int            @default(0)
  sentAt       DateTime?
  deliveredAt  DateTime?
  nextRetryAt  DateTime?
  createdAt    DateTime       @default(now())
  createdById  String?
  createdBy    User?          @relation(fields: [createdById], references: [id])
  webhook      Webhook        @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
  @@index([webhookId, status])
  @@index([status, nextRetryAt])
  @@map("webhook_deliveries")
}

model SlackIntegration {
  id             String    @id @default(cuid())
  workspaceId    String    @unique
  slackTeamId    String    @unique
  slackTeamName  String
  accessToken    String?
  webhookUrl     String?
  defaultChannel String?
  isActive       Boolean   @default(true)
  connectedAt    DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([slackTeamId])
  @@map("slack_integrations")
}

model AIUsage {
  id           String    @id @default(cuid())
  userId       String
  workspaceId  String
  date         DateTime  @default(now()) @db.Date
  requestCount Int       @default(0)
  tokenCount   Int       @default(0)
  inputTokens  Int       @default(0)
  outputTokens Int       @default(0)
  costCents    Int       @default(0)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, date])
  @@index([workspaceId, date])
  @@index([userId, date])
  @@map("ai_usage")
}

// Better Auth integrated User model - extended with application fields
model User {
  id                      String              @id @default(cuid())
  email                   String              @unique
  emailVerified           Boolean             @default(false)
  name                    String?
  image                   String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  
  // Application fields
  notificationPreferences Json?               @default("{\"cycleUpdates\": false, \"weeklyDigest\": true, \"issueAssigned\": true, \"issueMentioned\": true, \"emailNotifications\": true}")
  
  // Relations
  accounts                Account[]
  sessions                Session[]
  activities              Activity[]
  conversations           AgentConversation[]
  aiUsage                 AIUsage[]
  commentReactions        CommentReaction[]
  comments                Comment[]
  addedGroupMembers       GroupMember[]       @relation("GroupMemberAddedBy")
  groupMemberships        GroupMember[]
  createdGroups           Group[]
  sentInvitations         Invitation[]        @relation("SentInvitations")
  createdIssueNoteLinks   IssueNoteLink[]
  issueSubscriptions      IssueSubscription[]
  suggestedIssues         IssueSuggestion[]   @relation("SuggestedAssignee")
  issues                  Issue[]             @relation("IssueAssignee")
  createdIssues           Issue[]             @relation("IssueCreator")
  noteSubscriptions       NoteSubscription[]
  createdNotes            Note[]              @relation("NoteCreator")
  editedNotes             Note[]              @relation("NoteEditor")
  notifications           Notification[]      @relation("NotificationRecipient")
  actedNotifications      Notification[]      @relation("NotificationActor")
  personalTasks           PersonalTask[]
  retros                  SprintRetro[]
  teams                   TeamMember[]
  triageOwnedTeams        Team[]              @relation("TriageOwner")
  templates               Template[]
  issueViews              IssueView[]
  uploads                 Upload[]
  attachedFiles           IssueAttachment[]
  webhookDeliveries       WebhookDelivery[]
  webhookEvents           WebhookEvent[]
  webhooks                Webhook[]
  workspaceMembers        WorkspaceMember[]
  workspaces              Workspace[]
  sharedNotes             NoteShare[]           @relation("NoteShareInvitedBy")
  noteInvitations         NoteShare[]
  noteVersions            NoteVersion[]

  @@map("users")
}

